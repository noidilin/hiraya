# Vintage Database Configuration
# Environment variables for local database connections

export DB_HOST=localhost
export DB_PORT=5432
export DB_USER=postgres
export DB_PASSWORD=your_password_here

# Service-aligned databases
export AUTH_DB_NAME=auth_db
export PRODUCTS_DB_NAME=products_db
export ORDERS_DB_NAME=orders_db
export USERS_DB_NAME=users_db

export AUTH_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${AUTH_DB_NAME}"
export PRODUCTS_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${PRODUCTS_DB_NAME}"
export ORDERS_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${ORDERS_DB_NAME}"
export USERS_DB_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${USERS_DB_NAME}"

# Obsolete fallback/demo database name, retained only for standalone scripts.
export DB_NAME=vintage_auth
export DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

export DB_SSLMODE=prefer
export DB_POOL_MIN=2
export DB_POOL_MAX=10
