{
  "name": "vintage-microservices",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise microservices vintage application",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "install:all": "corepack pnpm@9.15.9 install",
    "check:workspace": "corepack pnpm@9.15.9 install --frozen-lockfile && corepack pnpm@9.15.9 list --recursive --depth -1",
    "catalog:validate": "node ../../.github/scripts/validate-service-catalog.mjs ../../.github/utils/services.json --root ../..",
    "catalog:changed": "node ../../.github/scripts/detect-changed-services.mjs --catalog ../../.github/utils/services.json --root ../..",
    "test:catalog": "node --test ../../.github/scripts/validate-service-catalog.test.mjs ../../.github/scripts/detect-changed-services.test.mjs",
    "dev": "concurrently \"corepack pnpm@9.15.9 run dev:frontend\" \"corepack pnpm@9.15.9 run dev:backend\"",
    "dev:frontend": "corepack pnpm@9.15.9 --filter frontend start",
    "dev:backend": "corepack pnpm@9.15.9 --filter vintage-backend dev:services",
    "test": "corepack pnpm@9.15.9 run test:frontend && corepack pnpm@9.15.9 run test:backend",
    "test:frontend": "corepack pnpm@9.15.9 --filter frontend test",
    "test:backend": "corepack pnpm@9.15.9 --filter vintage-backend test",
    "build": "corepack pnpm@9.15.9 run build:frontend && corepack pnpm@9.15.9 run build:backend",
    "build:frontend": "corepack pnpm@9.15.9 --filter frontend build",
    "build:backend": "corepack pnpm@9.15.9 --filter vintage-backend build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
