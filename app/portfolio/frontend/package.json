{
  "name": "@hiraya/portfolio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3002",
    "dev": "vite --host 0.0.0.0 --port 3002",
    "build": "tsc -b --pretty false && vite build",
    "typecheck": "tsc -b --pretty false --noEmit",
