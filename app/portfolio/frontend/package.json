    "test": "vitest run --dir src",
    "preview": "vite preview --host 0.0.0.0 --port 3002"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
