# Copy to bootstrap.auto.tfvars if you need to override defaults.

aws_region = "ap-northeast-1"

project_name = "hiraya"
environment  = "dev"

github_repository = "noidilin/hiraya"

# Increment intentionally to rotate the durable Vintage Storefront dev secret.
vintage_secret_rotation_epoch = "1"

repositories = [
  "hiraya-frontend",
  "hiraya-gateway",
  "hiraya-auth",
  "hiraya-order-service",
  "hiraya-orders",
  "hiraya-product-service",
  "hiraya-user-service"
]

tags = {}
