{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiraya.local/schemas/standards-alignment.schema.json",
  "title": "Hiraya Standards Alignment Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "standard", "mappings"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "version", "referenceUrl"],
      "properties": {
        "id": { "$ref": "#/$defs/standardName" },
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "referenceUrl": { "type": "string", "format": "uri" }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping" }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standardControlId",
        "standardControlTitle",
        "standardControlFamily",
        "projectControlIds",
        "alignmentStatus",
        "notes",
        "gapSummary"
      ],
      "properties": {
        "standardControlId": { "type": "string", "minLength": 1 },
        "standardControlTitle": { "type": "string", "minLength": 1 },
        "standardControlFamily": { "type": "string", "minLength": 1 },
        "projectControlIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" }
        },
        "alignmentStatus": { "$ref": "#/$defs/alignmentStatus" },
        "notes": { "type": "string", "minLength": 1 },
        "gapSummary": { "type": "string", "minLength": 1 },
        "sortKey": { "type": "integer", "minimum": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "alignmentStatus": { "const": "not_applicable" }
            },
            "required": ["alignmentStatus"]
          },
          "else": {
            "properties": {
              "projectControlIds": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "alignmentStatus": {
      "type": "string",
      "enum": [
        "aligned",
        "partially_aligned",
        "not_aligned",
        "not_applicable",
        "accepted_risk",
        "external_dependency"
      ]
    },
    "standardName": {
      "type": "string",
      "enum": [
        "aws_well_architected_security_pillar",
        "cis_aws_foundations_benchmark",
        "cis_kubernetes_eks_benchmark",
        "nist_csf_2",
        "slsa"
      ]
    }
  }
}
